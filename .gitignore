# environments
.venv/

# python related
__pycache__/
.pytest_cache/
.coverage
htmlcov/

# generated by orchestrator/generate.py, source of truth is ctf-config.yaml.
infrastructure/clab-up.sh
infrastructure/clab-down.sh
infrastructure/routers/generated/
zones/enterprise/docker-compose.yml
zones/operational/docker-compose.yml
zones/control/docker-compose.yml
zones/internet/docker-compose.yml
zones/dmz/docker-compose.yml
zones/internet/components/unseen-gate/adversary-readme.txt

# clab runtime state, one directory per deployed topology
clab/clab-uupl-*/

# lab keypair, generated on first ./ctl up, operator access only, never distributed
lab-key
lab-key.pub

# cohort keypair, generated by ./ctl cohort-keys, private key distributed to participants
cohort-key
cohort-key.pub

# runtime secrets, never commit
zones/internet/components/unseen-gate/adversary-keys

# TLS certs, generated by orchestrator/generate.py into certs/
# Re-run ./ctl generate to regenerate. Never commit private keys.
certs/

# CTF walkthroughs, kept private
books/
books/*
docs/
docs/*
challenges/
challenges/*
state.md

# captured traffic, too large for git
data/pcap/
.idea/
