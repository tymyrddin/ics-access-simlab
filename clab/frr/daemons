# FRR daemons file for the lab's inter-zone routers.
#
# zebra and staticd carry the existing inter-zone fabric (statically routed
# via the gateway addresses in each frr.conf). ospfd is enabled to expose
# a realistic OT-vendor-default routing-protocol attack surface: area 0,
# no MD5 auth, no passive-interface, no route filtering on redistribute.
# Static routes win on overlap (lower admin-distance), so OSPF runs as a
# parallel control plane that visitors can manipulate.

bgpd=no
ospfd=yes
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no
pathd=no
zebra=yes
staticd=yes

# Common option overrides. Each daemon-specific *_options line is honoured
# when that daemon is yes.
zebra_options="  -A 127.0.0.1 -s 90000000"
staticd_options="-A 127.0.0.1"
ospfd_options=" -A 127.0.0.1"
