# FRR daemons file for ops-ctrl-fw.
#
# Only zebra (kernel route programming) and staticd (static route handling)
# are enabled in this PoC. OSPF / BGP are disabled deliberately: this lab's
# inter-zone routing is static today, and the runbook chains do not test
# routing-protocol attacks yet. Future work that adds OSPF or BGP
# misconfiguration as attack surface enables ospfd / bgpd here.

bgpd=no
ospfd=no
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no
pathd=no
zebra=yes
staticd=yes

# Common option overrides. Each daemon-specific *_options line is honoured
# when that daemon is yes; with the daemons disabled above, only zebra and
# staticd options apply.
zebra_options="  -A 127.0.0.1 -s 90000000"
staticd_options="-A 127.0.0.1"
